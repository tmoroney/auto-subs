{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "AutoSubs",
  "version": "3.5.3",
  "identifier": "com.autosubs",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "titleBarStyle": "Overlay",
        "decorations": true,
        "trafficLightPosition": {
          "x": 10,
          "y": 20
        },
        "height": 700,
        "width": 900,
        "acceptFirstMouse": true,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DESKTOP/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$RESOURCE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/"],
    "macOS": {
      "minimumSystemVersion": "13.3"
    },
    "linux": {
      "deb": {
        "desktopTemplate": "./linux/autosubs.desktop",
        "depends": ["ffmpeg"],
        "files": {
          "/opt/resolve/Fusion/Scripts/Utility/AutoSubs.lua": "resources/AutoSubs.lua",
          "/usr/lib/autosubs/resources/AutoSubs.lua": "resources/AutoSubs.lua",
          "/usr/lib/autosubs/resources/modules": "resources/modules/"
        }
      },
      "rpm": {
        "desktopTemplate": "./linux/autosubs.desktop",
        "epoch": 0,
        "release": "1",
        "depends": [
          "webkit2gtk4.1",
          "openssl",
          "libappindicator-gtk3",
          "librsvg2",
          "ffmpeg"
        ],
        "files": {
          "/opt/resolve/Fusion/Scripts/Utility/AutoSubs.lua": "resources/AutoSubs.lua",
          "/usr/lib/autosubs/resources/AutoSubs.lua": "resources/AutoSubs.lua",
          "/usr/lib/autosubs/resources/modules": "resources/modules/"
        }
      }
    },
    "windows": {
      "nsis": {
        "template": "./windows/custom_installer.nsi",
        "installerHooks": "./windows/hooks.nsi",
        "installerIcon": "icons/icon.ico"
      },
      "certificateThumbprint": "4913cafc886d055b1634b0e191ede45034563b4a",
      "timestampUrl": "http://time.certum.pl",
      "digestAlgorithm": "sha256",
      "signCommand": {
        "cmd": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "./windows/sign.ps1",
          "%1"
        ]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFENjNBQjZFRkVCQTQxQTkKUldTcFFiciticXRqcmZtTlRWRzdnSHhBMFVNZkxvOGFRZThXdXFNQjFzakxqNDF0bUFyWkhwckUK",
      "endpoints": [
        "https://github.com/tmoroney/auto-subs/releases/latest/download/latest.json"
      ]
    }
  }
}
